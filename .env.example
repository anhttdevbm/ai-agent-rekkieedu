OPENROUTER_API_KEY=sk-or-v1-...
# Mặc định: anthropic/claude-sonnet-4.6 (hoặc vd. nvidia/nemotron-3-super-120b-a12b:free)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
# Tùy chọn: gửi kèm cho OpenRouter
OPENROUTER_HTTP_REFERER=https://localhost
OPENROUTER_APP_TITLE=Agent Edu

# Lark / Feishu (tuỳ chọn) — lấy link YouTube từ Bitable tab "Chấm hoạt động nhóm"
# Cách A — Custom App: quyền bitable:app hoặc bitable:app:readonly; thêm app vào Base.
# LARK_OPEN_API_BASE=https://open.larksuite.com/open-apis
# LARK_APP_ID=cli_xxxxxxxx
# LARK_APP_SECRET=xxxxxxxx
# Tuỳ chọn — mặc định trùng Base Rikkei Education (đổi nếu dùng bảng khác)
# LARK_BITABLE_APP_TOKEN=QumebR4fVa8pjHszEetlqpEOgkd
# LARK_BITABLE_TABLE_ID=tblDcfxiZ9YVdy8D
# Múi giờ dùng khi chọn ngày cụ thể (ExactDate) trên UI — mặc định VN
# LARK_BITABLE_DATE_TIMEZONE=Asia/Ho_Chi_Minh
#
# Cách B — không cần biến env: trên UI "Chấm hoạt động nhóm" dán Bearer + Cookie từ DevTools (request records/search).
